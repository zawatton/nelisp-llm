;;; gpu-adam-test.el --- on-device Adam optimiser correctness  -*- lexical-binding: t; -*-
;; Trains a block on-device with the Adam optimiser (per-parameter m/v kept
;; resident, updated in place by the adam kernel; lr_t refreshed per step) and
;; checks the loss trajectory matches a CPU reference running the same Adam
;; update.  Skips (exit 0) without a Vulkan device.
;;   emacs -Q --batch -L lisp -L ../nelisp-photon/lisp -l test/gpu-adam-test.el
(add-to-list 'load-path (expand-file-name "lisp"))
(add-to-list 'load-path (expand-file-name "../nelisp-photon/lisp"))
(require 'cl-lib)
(require 'photon-tensor)
(require 'photon-autograd)
(require 'nl-llm-autograd)
(require 'nl-llm-gpu)
(require 'nl-llm-gpu-ag)

(defvar ga--fail 0)
(defun ga--ck (name ok &optional extra)
  (princ (format "%-46s %s  %s\n" name
                 (if ok "PASS" (progn (setq ga--fail (1+ ga--fail)) "FAIL")) (or extra ""))))
(defun ga--t (shape seed sc) (let ((n 1)) (dolist (d shape) (setq n (* n d)))
  (photon-tensor shape (let ((v (make-vector n 0.0)) (i 0))
    (while (< i n) (aset v i (* sc 2.0 (- (/ (float (mod (+ (* (1+ i) 2654435761) (* (1+ seed) 40503)) 65536)) 65536.0) 0.5))) (setq i (1+ i))) v))))
(defun ga--ones (n) (photon-tensor (list n) (make-vector n 1.0)))
(defun ga--zeros (sh) (let ((n 1)) (dolist (d sh) (setq n (* n d))) (photon-tensor sh (make-vector n 0.0))))
(defun ga--cp (tn) (photon-tensor (photon-tensor-shape tn) (copy-sequence (photon-tensor-data tn))))
(defun ga--ce (ld seq vocab tg) (let ((loss 0.0) (i 0))
  (while (< i seq) (let ((base (* i vocab)) (mx -1.0e30) (j 0))
    (while (< j vocab) (when (> (aref ld (+ base j)) mx) (setq mx (aref ld (+ base j)))) (setq j (1+ j)))
    (let ((s 0.0) (j2 0)) (while (< j2 vocab) (setq s (+ s (exp (- (aref ld (+ base j2)) mx)))) (setq j2 (1+ j2)))
      (setq loss (- loss (- (- (aref ld (+ base (aref tg i))) mx) (log s)))))) (setq i (1+ i))) (/ loss (float seq))))

(unless (nl-llm-gpu-enable)
  (princ "NL-LLM-GPU-ADAM SKIP (no GPU server / Vulkan device)\n") (kill-emacs 0))

(let* ((seq 6) (dim 16) (heads 4) (kvh 2) (ff 24) (vocab 12) (hd (/ dim heads)) (kvdim (* kvh hd))
       (lr 0.01) (b1 0.9) (b2 0.999) (eps 1.0e-8) (steps 8) (sc 0.4) (scl (/ 1.0 (sqrt (float hd))))
       (targets (vector 1 2 3 4 5 6))
       (x (ga--t (list seq dim) 1 sc))
       (blk0 (list :ln1g (ga--ones dim) :wq (ga--t (list dim dim) 2 sc) :bq (ga--zeros (list dim))
                   :wk (ga--t (list kvdim dim) 3 sc) :bk (ga--zeros (list kvdim))
                   :wv (ga--t (list kvdim dim) 4 sc) :bv (ga--zeros (list kvdim))
                   :wo (ga--t (list dim dim) 5 sc) :bo (ga--zeros (list dim)) :ln2g (ga--ones dim)
                   :wg (ga--t (list ff dim) 6 sc) :bg (ga--zeros (list ff))
                   :wu (ga--t (list ff dim) 7 sc) :bu (ga--zeros (list ff))
                   :wd (ga--t (list dim ff) 8 sc) :bd (ga--zeros (list dim))))
       (lnfg (ga--ones dim)) (Wh (ga--t (list vocab dim) 9 sc)) (bh (ga--zeros (list vocab)))
       (tables (nl-llm-gpu-rope-tables seq hd))
       (onehot (let ((v (make-vector (* seq vocab) 0.0)) (i 0)) (while (< i seq) (aset v (+ (* i vocab) (aref targets i)) 1.0) (setq i (1+ i))) (photon-tensor (list seq vocab) v)))
       (mask (let ((md (make-vector (* seq seq) 0.0)) (i 0)) (while (< i seq) (let ((j (1+ i))) (while (< j seq) (aset md (+ (* i seq) j) -1.0e30) (setq j (1+ j)))) (setq i (1+ i))) (photon-tensor (list seq seq) md)))
       (gpu-losses nil) (cpu-losses nil))
  ;; ---- GPU: on-device Adam ----
  (let* ((b (nlga-new)) (wb (lambda (bt) (let ((o nil) (kv bt)) (while kv (push (car kv) o) (push (nlga-param b (ga--cp (cadr kv))) o) (setq kv (cddr kv))) (nreverse o))))
         (xr (nlga-const b (ga--cp x))) (g0 (funcall wb blk0))
         (lnfgr (nlga-param b (ga--cp lnfg))) (whr (nlga-param b (ga--cp Wh))) (bhr (nlga-param b (ga--cp bh)))
         (cosr (nlga-const b (car tables))) (sinr (nlga-const b (cdr tables)))
         (sposr (nlga-scalar b 1.0)) (snegr (nlga-scalar b -1.0)) (sclr (nlga-scalar b scl)) (oner (nlga-scalar b 1.0))
         (maskr (nlga-const b mask)) (ohr (nlga-const b onehot))
         (x2 (nlga-block b xr g0 heads kvh cosr sinr sposr snegr sclr maskr))
         (xf (nlga-rmsnorm b x2 lnfgr)) (logits (nlga-linear b xf whr bhr)) (lout (nlga-keep b logits oner)))
    (nlga-seed-ce b logits ohr) (nlga-finish-adam b lr b1 b2 eps) (nlga-compile b)
    (let ((tt 1)) (while (<= tt steps)
      (nlga-adam-update-t b tt)
      (push (ga--ce (nth lout (nlga-step b)) seq vocab targets) gpu-losses)
      (setq tt (1+ tt))))
    (nlga-free b))
  (setq gpu-losses (nreverse gpu-losses))
  (nl-llm-gpu-disable)
  ;; ---- CPU reference: same Adam update ----
  (let* ((P (lambda (tn) (photon-autograd-const (ga--cp tn))))
         (xc (funcall P x)) (c0 (let ((o nil) (kv blk0)) (while kv (push (car kv) o) (push (funcall P (cadr kv)) o) (setq kv (cddr kv))) (nreverse o)))
         (lnfgc (funcall P lnfg)) (whc (funcall P Wh)) (bhc (funcall P bh))
         (params (append (let ((o nil) (kv c0)) (while kv (push (cadr kv) o) (setq kv (cddr kv))) (nreverse o)) (list lnfgc whc bhc)))
         (ms (mapcar (lambda (p) (make-vector (length (photon-tensor-data (pav-value p))) 0.0)) params))
         (vs (mapcar (lambda (p) (make-vector (length (photon-tensor-data (pav-value p))) 0.0)) params))
         (tt 1))
    (while (<= tt steps)
      (photon-autograd-reset-tape)
      (let* ((x2 (nl-llm-ag-block xc c0 heads kvh)) (xf (nl-llm-ag-rmsnorm x2 lnfgc))
             (logits (photon-autograd-linear xf whc bhc)) (loss (photon-autograd-softmax-ce logits targets)))
        (push (aref (photon-tensor-data (pav-value loss)) 0) cpu-losses)
        (photon-autograd-zero-grad params) (photon-autograd-backward loss)
        (let ((lr-t (* lr (/ (sqrt (- 1.0 (expt b2 tt))) (- 1.0 (expt b1 tt))))) (pl params) (ml ms) (vl vs))
          (while pl
            (let* ((p (car pl)) (mvv (car ml)) (vvv (car vl))
                   (gd (photon-tensor-data (pav-grad p))) (wd (photon-tensor-data (pav-value p)))
                   (n (length wd)) (i 0))
              (while (< i n)
                (let ((g (aref gd i)))
                  (aset mvv i (+ (* b1 (aref mvv i)) (* (- 1.0 b1) g)))
                  (aset vvv i (+ (* b2 (aref vvv i)) (* (- 1.0 b2) (* g g))))
                  (aset wd i (- (aref wd i) (* lr-t (/ (aref mvv i) (+ (sqrt (aref vvv i)) eps))))))
                (setq i (1+ i))))
            (setq pl (cdr pl) ml (cdr ml) vl (cdr vl)))))
      (setq tt (1+ tt)))
    (setq cpu-losses (nreverse cpu-losses)))
  (let ((maxrel 0.0) (i 0))
    (while (< i steps)
      (setq maxrel (max maxrel (/ (abs (- (nth i gpu-losses) (nth i cpu-losses))) (max 1e-4 (abs (nth i cpu-losses))))))
      (setq i (1+ i)))
    (ga--ck "on-device Adam == CPU Adam" (< maxrel 1e-1) (format "maxrel=%.2e" maxrel)))
  (ga--ck "on-device Adam decreases loss" (< (car (last gpu-losses)) (car gpu-losses))
          (format "loss %.4f -> %.4f" (car gpu-losses) (car (last gpu-losses))))
  (princ (format "GPU: %s\nCPU: %s\n"
                 (mapcar (lambda (l) (/ (round (* l 1000)) 1000.0)) gpu-losses)
                 (mapcar (lambda (l) (/ (round (* l 1000)) 1000.0)) cpu-losses)))
  (princ (format "NL-LLM-GPU-ADAM %s (%d failures)\n" (if (= ga--fail 0) "ALL-PASS" "HAS-FAILURES") ga--fail))
  (kill-emacs (if (= ga--fail 0) 0 1)))
;;; gpu-adam-test.el ends here
